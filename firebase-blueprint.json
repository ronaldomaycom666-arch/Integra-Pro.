{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Business customer",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transaction",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["completed", "pending", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date" },
        "observations": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["items", "total", "createdAt", "userId", "paymentStatus"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Application global settings",
      "type": "object",
      "properties": {
        "lowStockThreshold": { "type": "number" },
        "currency": { "type": "string" },
        "companyName": { "type": "string" },
        "companyLogo": { "type": "string" },
        "cnpj": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "socialMedia": {
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "facebook": { "type": "string" },
            "whatsapp": { "type": "string" }
          }
        }
      },
      "required": ["lowStockThreshold", "currency", "companyName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory items"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer records"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales transactions"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global settings"
    }
  }
}
